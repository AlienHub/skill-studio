{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skill Studio",
  "version": "0.1.3",
  "identifier": "studio.skill.studio",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:5176",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Skill Studio",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "backgroundColor": "#fafafa"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDQ0UyRjY3RkEyNzc0RDgKUldUWWRDZjZaeS9PTExHWFgwSEhXVW1zZDh5OXFQV2c4NVg3TEhWUHI1OFVncW15UWFkcCsydjAK",
      "endpoints": [
        "https://github.com/AlienHub/skill-studio/releases/latest/download/latest.json"
      ]
    }
  }
}
